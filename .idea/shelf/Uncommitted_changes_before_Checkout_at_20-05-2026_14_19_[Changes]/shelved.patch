xt-red-500 transition-all\">\r\n                <i class=\"fa-solid fa-power-off\"></i> Sign Out\r\n            </button>\r\n        </form>\r\n    </div>\r\n</aside>\r\n\r\n<main class=\"flex-1 p-6 md:p-10\">\r\n    <header class=\"mb-8\">\r\n        <h1 class=\"text-3xl font-extrabold tracking-tight\">Medical <span class=\"text-emerald-600\">Timeline</span></h1>\r\n        <p class=\"text-slate-500 mt-1\">Detailed record of your past consultations and prescriptions</p>\r\n    </header>\r\n\r\n    <div th:if=\"${param.success}\" class=\"mb-6 p-4 bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-2xl flex items-center gap-3\">\r\n        <i class=\"fa-solid fa-circle-check\"></i>\r\n        <span class=\"text-sm font-bold\">Appointment booked successfully!</span>\r\n    </div>\r\n\r\n    <div class=\"premium-card\">\r\n        <table class=\"w-full text-left\">\r\n            <thead class=\"bg-slate-50 border-b border-slate-100\">\r\n            <tr>\r\n                <th class=\"px-8 py-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest\">Medical Specialist</th>\r\n                <th class=\"px-8 py-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest\">Date & Time</th>\r\n                <th class=\"px-8 py-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest\">Status</th>\r\n                <th class=\"px-8 py-5 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-right\">Actions</th>\r\n            </tr>\r\n            </thead>\r\n            <tbody class=\"divide-y divide-slate-100\">\r\n            <tr th:each=\"app : ${appointments}\" class=\"hover:bg-slate-50/50 transition-all group\">\r\n                <td class=\"px-8 py-5\">\r\n                    <div class=\"flex items-center gap-3\">\r\n                        <div class=\"w-10 h-10 bg-slate-100 rounded-full flex items-center justify-center text-slate-400 group-hover:bg-emerald-100 group-hover:text-emerald-600 transition-all\">\r\n  